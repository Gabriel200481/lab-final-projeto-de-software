@startuml diagrama-comunicacao-resgate-qrcode
title Diagrama de comunicacao: resgate com QR code

object "ResgateController" as RC
object "ResgateService" as RS
object "AlunoRepository" as AR
object "VantagemRepository" as VR
object "ResgateVantagemRepository" as RR
object "QrCodeService" as QR
object "CupomRepository" as CR
object "NotificacaoService" as NS

RC -> RS : 1 resgatar(request)
RS -> AR : 2 findById(alunoId)
RS -> VR : 3 findByIdAndAtivaTrue(vantagemId)
RS -> AR : 4 save(aluno saldo debitado)
RS -> RR : 5 save(resgate com codigo unico)
RS -> QR : 6 gerarQrCode(codigo, nomeArquivo)
RS -> CR : 7 save(cupom)
RS -> NS : 8 enviarConfirmacaoResgateParaAluno(...)
RS -> NS : 9 enviarConfirmacaoResgateParaEmpresa(...)
RS -> RC : 10 ResgateResponse

@enduml
