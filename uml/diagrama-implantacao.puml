@startuml diagrama-implantacao
title Diagrama de implantacao: alvo Release 3

node "Cliente Web" {
  component "Browser" as browser
}

cloud "Vercel" {
  component "Frontend estatico\nHTML/CSS/JS" as fe
}

cloud "Render" {
  node "Web Service" {
    component "Spring Boot API" as api
    component "JWT + Security" as sec
    component "QrCodeService" as qr
  }
  database "PostgreSQL" as db
}

cloud "SMTP" {
  component "Servidor de email" as smtp
}

folder "Storage de QR (qrcodes/)" as storage

browser --> fe : HTTPS
fe --> api : HTTPS /api
api --> sec : autenticar token
api --> db : JPA/Hibernate
api --> qr : gerar PNG
qr --> storage : salvar arquivo
api --> smtp : enviar notificacoes

@enduml
