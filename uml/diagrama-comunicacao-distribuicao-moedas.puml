@startuml Diagrama de Comunicação - Distribuição de Moedas

title Diagrama de Comunicação: Professor Distribui Moedas

object ":ProfessorController" as controller
object ":DistribuicaoMoedasService" as service
object ":TransacaoRepository" as repo
object ":EmailService" as email
object ":Logger" as log

controller --> controller : 1: validarAutenticacao()
controller --> service : 2: distribuir(100, "Mensagem", cursoId)
service --> service : 3: validarSaldoProfessor()
service --> repo : 4: save(novaTransacao)
repo --> repo : 5: flush()
service --> log : 6: logDistribuicao()
service --> email : 7: enviarEmailNotificacao()
email --> email : 8: construirTemplate()
service --> email : 9: send()
email --> email : 10: fallbackIfFailed()
service --> controller : 11: retornar(sucesso)
controller --> controller : 12: renderResponse()

note right of controller
  //Entrada da requisição//
  POST /api/distribuir
  {quantidade: 100, mensagem, cursoId}
end note

note right of service
  //Lógica de negócio//
  - Valida saldo >= 100
  - Cria transação
  - Envia email
  - Trata exceções
end note

note right of repo
  //Persistência//
  INSERT INTO TRANSACAO
  Saldo atualizado com rollback se falhar
end note

note right of email
  //Notificação externa//
  SMTP ou Fallback em arquivo
end note

@enduml
