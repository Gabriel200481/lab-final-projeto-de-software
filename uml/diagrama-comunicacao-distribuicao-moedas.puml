@startuml diagrama-comunicacao-distribuicao-moedas
title Diagrama de comunicacao: distribuicao de moedas

object "TransacaoController" as TC
object "TransacaoService" as TS
object "ProfessorRepository" as PR
object "AlunoRepository" as AR
object "TransacaoMoedaRepository" as TR
object "NotificacaoService" as NS

TC -> TS : 1 distribuirMoedas(request)
TS -> PR : 2 findById(professorId)
TS -> AR : 3 findById(alunoId)
TS -> TS : 4 validarDistribuicao(...)
TS -> PR : 5 save(professor saldo atualizado)
TS -> AR : 6 save(aluno saldo atualizado)
TS -> TR : 7 save(transacao)
TS -> NS : 8 enviarRecebimentoMoedasParaAluno(...)
TS -> NS : 9 enviarConfirmacaoDistribuicaoParaProfessor(...)
TS -> TC : 10 TransacaoResponse

@enduml
